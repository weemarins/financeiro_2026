# Backend Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
DATABASE_PATH=./data/financeiro.db

# JWT Configuration
JWT_SECRET=supersenha123456
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# Seed/Test Users
SEED_USER_PASSWORD=defina_uma_senha_temporaria_para_seed

# Bootstrap Admin User (não deixar valores reais versionados)
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=defina_uma_senha_forte
ADMIN_FAMILY_NAME=Administracao
