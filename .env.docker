# Docker Environment Variables
BACKEND_PORT=5000
FRONTEND_PORT=80

# Backend Configuration
NODE_ENV=production
JWT_SECRET=mudeme_em_producao_gere_uma_nova_chave_segura
ADMIN_NAME=Administrador Inicial
ADMIN_EMAIL=admin@financeiro.local
ADMIN_PASSWORD=admin123
